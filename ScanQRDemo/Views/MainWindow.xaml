<Window x:Class="ScanQRDemo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ScanQR Demo — Dashboard"
        Height="740" Width="1280"
        MinHeight="620" MinWidth="980"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Closing="Window_Closing">

    <Window.Resources>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Light-theme colour palette ─────────────────────────────────── -->
        <SolidColorBrush x:Key="BgPage"      Color="#EEF2F8"/>
        <SolidColorBrush x:Key="BgCard"      Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BgAlt"       Color="#F8FAFC"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="TextDark"    Color="#1E293B"/>
        <SolidColorBrush x:Key="TextMid"     Color="#475569"/>
        <SolidColorBrush x:Key="TextGray"    Color="#94A3B8"/>
        <SolidColorBrush x:Key="Blue"        Color="#3B82F6"/>
        <SolidColorBrush x:Key="BlueDark"    Color="#2563EB"/>
        <SolidColorBrush x:Key="BlueLight"   Color="#EFF6FF"/>
        <SolidColorBrush x:Key="Green"       Color="#16A34A"/>
        <SolidColorBrush x:Key="GreenLight"  Color="#F0FDF4"/>
        <SolidColorBrush x:Key="Red"         Color="#DC2626"/>
        <SolidColorBrush x:Key="RedHover"    Color="#EF4444"/>
        <SolidColorBrush x:Key="RedLight"    Color="#FEF2F2"/>
        <SolidColorBrush x:Key="Orange"      Color="#F97316"/>
        <SolidColorBrush x:Key="OrangeLight" Color="#FFF7ED"/>
        <SolidColorBrush x:Key="NavyDark"    Color="#1E293B"/>

        <!-- ── Button: Primary (blue) ─────────────────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource Blue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BlueDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Button: Danger (red) ───────────────────────────────────────── -->
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="{StaticResource Red}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource RedHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Button: Ghost (outlined) ──────────────────────────────────── -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="{StaticResource TextMid}"/>
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgAlt}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Thin light scrollbar ───────────────────────────────────────── -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="5"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Border Background="#E2E8F0" CornerRadius="3"/>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#94A3B8" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Card border helper ─────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="8"/>
        </Style>

        <!-- ── Table column header text ──────────────────────────────────── -->
        <Style x:Key="ColHeader" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="{StaticResource TextGray}"/>
        </Style>

        <!-- ── Button: Upload (indigo) ─────────────────────────────────── -->
        <Style x:Key="UploadBtn" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="Padding"         Value="16,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="Background"      Value="#7C3AED"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#6D28D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <!--                          ROOT GRID                                   -->
    <!-- ══════════════════════════════════════════════════════════════════════ -->
    <Grid Background="{StaticResource BgPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header bar      -->
            <RowDefinition Height="Auto"/>  <!-- Controls bar    -->
            <RowDefinition Height="*"/>     <!-- Main 2×2 grid   -->
            <RowDefinition Height="36"/>    <!-- Footer bar      -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: title + subtitle -->
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <!-- Monitor icon box -->
                        <Border Width="34" Height="34" CornerRadius="6"
                                Background="{StaticResource BlueLight}"
                                Margin="0,0,12,0" VerticalAlignment="Center">
                            <TextBlock Text="&#x25A3;" FontSize="16"
                                       Foreground="{StaticResource Blue}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Windows Desktop Application &#x2014; Dashboard"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextDark}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Real-time monitoring interface for batch scanning operations"
                               FontSize="12" Foreground="{StaticResource Blue}"
                               Margin="46,5,0,0"/>
                </StackPanel>

                <!-- Right: SOTATEK branding -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="14"
                            Background="{StaticResource BlueLight}" Margin="0,0,8,0">
                        <TextBlock Text="&#x25C6;" FontSize="13"
                                   Foreground="{StaticResource Blue}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="SOTATEK" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource TextDark}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ CONTROLS BAR ══════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{StaticResource BgCard}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,0,0,1"
                Padding="28,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="Camera:" FontSize="13"
                           Foreground="{StaticResource TextMid}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>

                <ComboBox ItemsSource="{Binding AvailableCameras}"
                          SelectedItem="{Binding SelectedCamera, Mode=TwoWay}"
                          DisplayMemberPath="Name"
                          Width="190" Height="34" Margin="0,0,8,0"
                          VerticalContentAlignment="Center"
                          Background="White"
                          BorderBrush="{StaticResource BorderColor}"/>

                <Button Content="Connect"
                        Style="{StaticResource PrimaryBtn}"
                        Command="{Binding ConnectCommand}"
                        Margin="0,0,6,0"/>

                <Button Content="Disconnect"
                        Style="{StaticResource DangerBtn}"
                        Command="{Binding DisconnectCommand}"
                        Margin="0,0,6,0"/>

                <Button Content="Capture"
                        Style="{StaticResource GhostBtn}"
                        Command="{Binding CaptureCommand}"
                        Margin="0,0,8,0"/>

                <Button Content="&#x2B06; Upload Image"
                        Style="{StaticResource UploadBtn}"
                        Command="{Binding UploadImageCommand}"
                        Margin="0,0,20,0"/>

                <!-- Separator -->
                <Border Width="1" Height="22" Background="{StaticResource BorderColor}" Margin="0,0,20,0"/>

                <!-- Status pill -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <Ellipse Width="8" Height="8" Fill="{Binding StatusBrush}" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextDark}" VerticalAlignment="Center"/>
                </StackPanel>

                <Border Width="1" Height="22" Background="{StaticResource BorderColor}" Margin="0,0,20,0"/>

                <Button Content="Clear Results"
                        Style="{StaticResource GhostBtn}"
                        Command="{Binding ClearResultsCommand}"/>
            </StackPanel>
        </Border>

        <!-- ══ MAIN 2×2 GRID ═════════════════════════════════════════════════ -->
        <Grid Grid.Row="2" Margin="16,12,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="3*"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="2*"/>
            </Grid.RowDefinitions>

            <!-- ┌─────────────────────────────────────────────────────────┐ -->
            <!-- │  [0,0]  Live Camera Feed                                │ -->
            <!-- └─────────────────────────────────────────────────────────┘ -->
            <Border Grid.Row="0" Grid.Column="0"
                    Style="{StaticResource Card}"
                    BorderBrush="{StaticResource Blue}"
                    BorderThickness="1.5"
                    ClipToBounds="True">
                <Border.Effect>
                    <DropShadowEffect Color="#3B82F6" BlurRadius="10"
                                      ShadowDepth="0" Opacity="0.12"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Card header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="16,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="26" Height="26" CornerRadius="5"
                                        Background="{StaticResource BlueLight}"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="&#x25A3;" FontSize="13"
                                               Foreground="{StaticResource Blue}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Live Camera Feed"
                                           FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource TextDark}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- LIVE badge (visible only when running) -->
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource Green}" Margin="0,0,5,0">
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.2"
                                                                     Duration="0:0:0.8" AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="Live" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource Green}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Camera viewport -->
                    <Border Grid.Row="1" Background="#0F172A" ClipToBounds="True">
                        <Grid>
                            <!-- Disconnected placeholder -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding IsNotRunning, Converter={StaticResource BoolToVis}}">
                                <Border Width="60" Height="60" CornerRadius="30"
                                        Background="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,14">
                                    <TextBlock Text="&#x25A3;" FontSize="26"
                                               Foreground="#334155"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Camera feed will appear here"
                                           Foreground="#475569" FontSize="14"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- FOV label (top-left overlay, visible when running) -->
                            <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                    Margin="12,10,0,0" Background="#1E293B"
                                    CornerRadius="4" Padding="8,4"
                                    Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="#64748B"
                                             VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="80&#xD7;80 cm FOV"
                                               FontSize="11" Foreground="#94A3B8"/>
                                </StackPanel>
                            </Border>

                            <!-- Live image -->
                            <Image Source="{Binding CameraImage}"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="LowQuality"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ┌─────────────────────────────────────────────────────────┐ -->
            <!-- │  [0,2]  Decoded Data                                    │ -->
            <!-- └─────────────────────────────────────────────────────────┘ -->
            <Border Grid.Row="0" Grid.Column="2"
                    Style="{StaticResource Card}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46"/>   <!-- Header -->
                        <RowDefinition Height="36"/>   <!-- Column headers -->
                        <RowDefinition Height="*"/>    <!-- Rows -->
                    </Grid.RowDefinitions>

                    <!-- Card header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="16,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="26" Height="26" CornerRadius="5"
                                        Background="#EEF2FF" Margin="0,0,8,0">
                                    <TextBlock Text="&#x229E;" FontSize="14"
                                               Foreground="{StaticResource Blue}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Decoded Data"
                                           FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource TextDark}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Last updated: " FontSize="12"
                                           Foreground="{StaticResource TextGray}"/>
                                <TextBlock Text="{Binding LastUpdatedText}" FontSize="12"
                                           Foreground="{StaticResource TextGray}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Column headers row -->
                    <Border Grid.Row="1"
                            Background="{StaticResource BgAlt}"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="16,0">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="65"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="SKU"     Style="{StaticResource ColHeader}"/>
                            <TextBlock Grid.Column="1" Text="Barcode" Style="{StaticResource ColHeader}"/>
                            <TextBlock Grid.Column="2" Text="Status"  Style="{StaticResource ColHeader}"/>
                            <TextBlock Grid.Column="3" Text="Time"    Style="{StaticResource ColHeader}"/>
                        </Grid>
                    </Border>

                    <!-- Data rows (scrollable) -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding QRResults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource BorderColor}"
                                            BorderThickness="0,0,0,1"
                                            Padding="16,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="65"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding SkuId}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource BlueDark}"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Text}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextDark}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding Text}"/>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Status}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource Green}"/>

                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding LastSeen, StringFormat=HH:mm:ss}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextGray}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ┌─────────────────────────────────────────────────────────┐ -->
            <!-- │  [2,0]  Batch Statistics                                │ -->
            <!-- └─────────────────────────────────────────────────────────┘ -->
            <Border Grid.Row="2" Grid.Column="0"
                    Style="{StaticResource Card}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Card header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="16,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="26" Height="26" CornerRadius="5"
                                        Background="{StaticResource GreenLight}"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="&#x2261;" FontSize="16"
                                               Foreground="{StaticResource Green}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Batch Statistics"
                                           FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource TextDark}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right"
                                       FontSize="12" Foreground="{StaticResource TextGray}"
                                       VerticalAlignment="Center">
                                <Run Text="Total: "/>
                                <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                                <Run Text=" packages"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- 3 stat boxes -->
                    <Grid Grid.Row="1" Margin="16,8,16,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Success -->
                        <Border Grid.Column="0" Background="{StaticResource BgAlt}"
                                CornerRadius="6" Padding="8">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DetectedCount, Mode=OneWay}"
                                           FontSize="34" FontWeight="Bold"
                                           Foreground="{StaticResource TextDark}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Success" FontSize="12"
                                           Foreground="{StaticResource TextGray}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Failed -->
                        <Border Grid.Column="2" Background="{StaticResource BgAlt}"
                                CornerRadius="6" Padding="8">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding FailedCount, Mode=OneWay}"
                                           FontSize="34" FontWeight="Bold"
                                           Foreground="{StaticResource TextDark}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Failed" FontSize="12"
                                           Foreground="{StaticResource TextGray}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Accuracy -->
                        <Border Grid.Column="4" Background="{StaticResource BgAlt}"
                                CornerRadius="6" Padding="8">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AccuracyText, Mode=OneWay}"
                                           FontSize="34" FontWeight="Bold"
                                           Foreground="{StaticResource TextDark}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Accuracy" FontSize="12"
                                           Foreground="{StaticResource TextGray}"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- ┌─────────────────────────────────────────────────────────┐ -->
            <!-- │  [2,2]  Exception Queue                                 │ -->
            <!-- └─────────────────────────────────────────────────────────┘ -->
            <Border Grid.Row="2" Grid.Column="2"
                    Style="{StaticResource Card}">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.06"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="46"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Card header -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderColor}"
                            BorderThickness="0,0,0,1"
                            Padding="16,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="26" Height="26" CornerRadius="5"
                                        Background="{StaticResource OrangeLight}"
                                        Margin="0,0,8,0">
                                    <TextBlock Text="&#x26A0;" FontSize="13"
                                               Foreground="{StaticResource Orange}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Exception Queue"
                                           FontWeight="SemiBold" FontSize="14"
                                           Foreground="{StaticResource TextDark}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock HorizontalAlignment="Right"
                                       FontSize="12" Foreground="{StaticResource TextGray}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding ExceptionCount, Mode=OneWay}"/>
                                <Run Text=" items pending"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- Exception items -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                        <ItemsControl ItemsSource="{Binding ExceptionItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource RedLight}"
                                            CornerRadius="6"
                                            Margin="0,0,0,6"
                                            Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="8" Height="8"
                                                     Fill="{StaticResource Red}"
                                                     VerticalAlignment="Center"
                                                     Margin="0,0,10,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Message}"
                                                       FontSize="12"
                                                       Foreground="{StaticResource TextDark}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding TimeText}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextGray}"
                                                       VerticalAlignment="Center"
                                                       Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ══ FOOTER ═════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                Background="{StaticResource BgPage}"
                BorderBrush="{StaticResource BorderColor}"
                BorderThickness="0,1,0,0"
                Padding="28,0">
            <Grid>
                <!-- Centre info text -->
                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="&#x24D8; " FontSize="12"
                               Foreground="{StaticResource TextGray}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="UI design to be refined during POC based on operator feedback"
                               FontSize="12" Foreground="{StaticResource TextGray}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: CONFIDENTIAL badge -->
                <Border HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="{StaticResource NavyDark}"
                        CornerRadius="4" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F512; " FontSize="11"
                                   Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="CONFIDENTIAL" FontSize="11" FontWeight="Bold"
                                   Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
